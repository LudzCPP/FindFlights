# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real credentials.

# ── Mock / Live toggle ────────────────────────────────────────────────────────
# 'true'  → use built-in mock data (default, no API key needed)
# 'false' → use Travelpayouts live API (requires token below)
VITE_USE_MOCK=true

# ── Travelpayouts / Aviasales Data API ───────────────────────────────────────
# 1. Register for FREE at https://www.travelpayouts.com/developers/api
# 2. After sign-up, go to: https://www.travelpayouts.com/developer/api
#    (left sidebar → "API" → your token is shown at the top of the page)
# 3. Paste it below, then set VITE_USE_MOCK=false
# 4. Restart `npm run dev` — the Vite proxy handles CORS automatically
VITE_TRAVELPAYOUTS_TOKEN=your_token_here

# ── Amadeus (kept for reference, currently not wired) ────────────────────────
# VITE_AMADEUS_CLIENT_ID=
# VITE_AMADEUS_CLIENT_SECRET=
