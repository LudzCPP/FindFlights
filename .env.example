# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — never commit real credentials.

# ── Mock / Live toggle ────────────────────────────────────────────────────────
# Set to 'false' to enable live Amadeus calls.
# Leave as 'true' (or omit entirely) to use built-in mock data.
VITE_USE_MOCK=true

# ── Amadeus for Developers ────────────────────────────────────────────────────
# 1. Register for free at https://developers.amadeus.com/
# 2. Go to "My Apps" → "Create New App"
# 3. Copy the Client ID and Client Secret below
# 4. The app uses the TEST environment (test.api.amadeus.com) — no billing needed
VITE_AMADEUS_CLIENT_ID=your_client_id_here
VITE_AMADEUS_CLIENT_SECRET=your_client_secret_here
